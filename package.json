{
  "name": "trivali",
  "version": "1.0.0",
  "description": "Dead simple Object schema validation",
  "main": "lib/index.js",
  "module": "lib/index.esm.js",
  "runkitExampleFilename": "./runkit-example.js",
  "scripts": {
    "test": "pnpm lint && pnpm testonly",
    "testonly": "vitest run",
    "test-sync": "vitest run --project sync",
    "tdd": "vitest --project async",
    "lint": "eslint src test",
    "precommit": "lint-staged",
    "toc": "doctoc README.md --github",
    "release": "rollout",
    "build": "rm -rf lib && pnpm vite build && pnpm toc",
    "prepublishOnly": "pnpm build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/khulnasoft-bot/trivali.git"
  },
  "author": {
    "name": "@monasticpanic Jason Quense"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/khulnasoft-bot/trivali/issues"
  },
  "homepage": "https://github.com/khulnasoft-bot/trivali",
  "release": {
    "conventionalCommits": true,
    "publishDir": "lib"
  },
  "prettier": {
    "singleQuote": true,
    "trailingComma": "all"
  },
  "lint-staged": {
    "*.{js,json,css,md}": [
      "prettier --write",
      "git add"
    ]
  },
  "devDependencies": {
    "@4c/cli": "^4.0.4",
    "@4c/rollout": "^4.0.2",
    "@babel/cli": "^7.22.9",
    "@babel/core": "^7.22.9",
    "@babel/preset-typescript": "^7.22.5",
    "@standard-schema/spec": "^1.1.0",
    "@types/minimatch": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "doctoc": "^2.2.1",
    "eslint": "^8.45.0",
    "eslint-config-jason": "^8.2.2",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-ts-expect": "^2.1.0",
    "eslint-plugin-typescript": "^0.14.0",
    "hookem": "^2.0.1",
    "lint-staged": "^13.2.3",
    "minimatch": "^10.1.1",
    "prettier": ">=3.0.0 <4",
    "synchronous-promise": "^2.0.17",
    "typescript": "^4.9.5",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0",
    "vitest": "^3.2.4",
    "@khulnasoft/style-guide": "^4.0.0"
  },
  "dependencies": {
    "property-expr": "^2.0.5",
    "tiny-case": "^1.0.3",
    "toposort": "^2.0.2",
    "type-fest": "^2.19.0"
  },
  "packageManager": "pnpm@8.15.7"
}
